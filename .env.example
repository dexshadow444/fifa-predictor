# ============================================================================
# FIREBASE (required) - your database
# ----------------------------------------------------------------------------
# Create a Firebase project at https://console.firebase.google.com, enable
# Firestore (Native mode), then Project Settings > Service Accounts >
# Generate new private key. That JSON file gives you these 3 values.
# ============================================================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Keep the quotes and \n escapes exactly as they appear in the downloaded JSON:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# ============================================================================
# ADMIN LOGIN (required) - bootstraps the FIRST admin account only
# ----------------------------------------------------------------------------
# Used once, the very first time anyone logs in to /admin, to create the
# admin account in Firestore. After that first login, go to the Admin Panel
# and change the password immediately - the app will use the Firestore
# record from then on, and you can safely remove these two variables.
# ============================================================================
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-this-before-first-deploy

# ============================================================================
# SESSION SECURITY (required)
# ----------------------------------------------------------------------------
# Any long random string, used to sign admin login sessions. Generate one
# with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================================
JWT_SECRET=replace-with-a-long-random-string

# ============================================================================
# CRON PROTECTION (optional, only if you enable Vercel Cron for daily sync)
# ----------------------------------------------------------------------------
# Any long random string. Must match what you set in your hosting provider's
# environment variables. Vercel sends this automatically as a Bearer token
# when your cron job (see vercel.json) fires.
# ============================================================================
CRON_SECRET=replace-with-another-long-random-string
